{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Mori",
  "basePath": "/docs",
  "theme": "maple",
  "colors": {
    "primary": "#69347A",
    "light": "#9B59B6",
    "dark": "#69347A"
  },
  "background": {
    "color": {
      "dark": "#0D0C07"
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "fonts": {
    "heading": {
      "family": "Manrope",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/components",
              "concepts/strategies",
              "concepts/safety"
            ]
          },
          {
            "group": "Database Engines",
            "pages": [
              "configuration/engines",
              "engines/postgres",
              "engines/cockroachdb",
              "engines/mysql",
              "engines/mariadb",
              "engines/mssql",
              "engines/sqlite",
              "engines/duckdb",
              "engines/redis",
              "engines/firestore"
            ]
          },
          {
            "group": "Providers",
            "pages": [
              "configuration/providers"
            ]
          },
          {
            "group": "Usage",
            "pages": [
              "usage/cli",
              "usage/ports",
              "usage/mcp",
              "usage/tui"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "resources/motivation",
              "resources/name",
              "resources/roadmap"
            ]
          },
          {
            "group": "Support",
            "pages": [
              "support/issues",
              "support/contributing",
              "support/sponsor",
              "support/contact"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/psrth/mori"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/psrth/mori"
    }
  }
}
